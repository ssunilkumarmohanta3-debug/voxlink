{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8080 --ip 0.0.0.0",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "wrangler d1 migrations apply voxlink-db --local",
    "db:seed": "wrangler d1 execute voxlink-db --local --file=./seed.sql"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.6.0",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}